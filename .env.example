# ─────────────────────────────────────────────────────────────
# WaxChat environment configuration. Copy to `.env.local` in apps/web
# and fill in. Values prefixed NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# --- WAX network ---------------------------------------------------------
# "testnet" (recommended for development) or "mainnet"
NEXT_PUBLIC_WAX_NETWORK=testnet
# Chain API endpoint. Testnet: https://testnet.waxsweden.org
# Mainnet: https://wax.greymass.com
NEXT_PUBLIC_WAX_RPC=https://testnet.waxsweden.org
# Optional override for the AtomicAssets API base.
# Testnet: https://test.wax.api.atomicassets.io  Mainnet: https://wax.api.atomicassets.io
NEXT_PUBLIC_ATOMIC_API=https://test.wax.api.atomicassets.io
# Hyperion history endpoint used by the chain-watcher (payment confirmation).
# Mainnet options: https://wax.eosusa.io  https://api.waxsweden.org
WAX_HYPERION_URL=https://wax.eosusa.io

# --- Supabase ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
# Server-only. Used by edge functions / server routes. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
# The JWT secret used to sign the Supabase-compatible session token minted
# after a successful Sign-In-With-WAX. Must match Supabase's JWT secret.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=WaxChat
# Destination wallet that receives paid-promotion payments / verified stakes
# in Phase 2 (until the escrow contract is deployed, this is informational).
NEXT_PUBLIC_TREASURY_ACCOUNT=waxchat.tres
