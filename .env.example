# ─────────────────────────────────────────────────────────────
# WaxChat environment configuration. Copy to `.env.local` in apps/web
# and fill in. Values prefixed NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# --- WAX network ---------------------------------------------------------
# "mainnet" or "testnet"
NEXT_PUBLIC_WAX_NETWORK=mainnet
# Chain API endpoint. Mainnet: https://wax.greymass.com
# Testnet: https://testnet.waxsweden.org
NEXT_PUBLIC_WAX_RPC=https://wax.greymass.com
# Optional override for the AtomicAssets API base.
# Mainnet: https://wax.api.atomicassets.io  Testnet: https://test.wax.api.atomicassets.io
NEXT_PUBLIC_ATOMIC_API=https://wax.api.atomicassets.io
# Hyperion history endpoint used by the chain-watcher (payment confirmation).
# Mainnet options: https://wax.eosusa.io  https://api.waxsweden.org
WAX_HYPERION_URL=https://wax.eosusa.io
# Optional WAX API gateway. Server routes add WAX_API_KEY; client code falls
# back to public endpoints where a secret would be required.
NEXT_PUBLIC_WAX_API_URL=
WAX_API_KEY=
# USD price feed for wallet token values (Alcor WAX token list by default).
# Prices are cached ~1h server-side. Leave unset to use the Alcor default.
WAX_PRICE_API_URL=https://wax.alcor.exchange/api/v2/tokens

# --- Supabase ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
# Server-only. Used by edge functions / server routes. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
# The JWT secret used to sign the Supabase-compatible session token minted
# after a successful Sign-In-With-WAX. For newer Supabase auth signing-keys
# projects, set SUPABASE_JWT_PRIVATE_JWK and SUPABASE_JWT_KID instead.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# Optional ES256 private JWK for Supabase projects using JWT signing keys.
SUPABASE_JWT_PRIVATE_JWK=
# Optional key id to send in the JWT header when signing with ES256.
SUPABASE_JWT_KID=

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=WaxChat
# Destination wallet that receives paid-promotion payments / verified stakes
# in Phase 2 (until the escrow contract is deployed, this is informational).
NEXT_PUBLIC_TREASURY_ACCOUNT=waxchat.tres
